{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "ota:production": "./scripts/ota.sh production",
    "ota:preview": "./scripts/ota.sh preview",
    "ota:development": "./scripts/ota.sh development",
    "build:production": "eas build --platform all --profile production --auto-submit",
    "build:preview": "eas build --platform all --profile preview",
    "build:development": "eas build --platform all --profile development"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.claude/worktrees/"
    ],
    "moduleNameMapper": {
      "^@sentry/react-native$": "<rootDir>/src/__mocks__/sentry.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|@sentry/.*|native-base|react-native-svg|nativewind))"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/quicksand": "^0.4.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/material-top-tabs": "^7.4.13",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@sentry/react-native": "^8.8.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-av": "^16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^0.460.0",
    "nativewind": "^4.2.1",
    "onesignal-expo-plugin": "^2.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-onesignal": "^5.4.1",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "4.1.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-tab-view": "^4.2.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "3.4.19",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "tailwindcss": "3.4.19",
    "react-native-worklets": "0.5.1",
    "react-native-pager-view": "6.9.1"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "^5.9.3"
  }
}
