{
  "expo": {
    "name": "Emotional Pulse",
    "slug": "mobile",
    "scheme": "emotionalpulse",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#9AAD82"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs microphone access to enable voice conversations with Pulse AI.",
        "NSLocationWhenInUseUsageDescription": "This app does not use your location."
      },
      "bundleIdentifier": "com.vative.stemotionalpulse",
      "appleTeamId": "PL8F7LAM2G"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#9AAD82"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sharetree.emotionalpulse"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/442160e5-834b-4247-af44-9f98fcd593ff"
    },
    "extra": {
      "eas": {
        "projectId": "442160e5-834b-4247-af44-9f98fcd593ff"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "sharetree"
        }
      ]
    ]
  }
}
