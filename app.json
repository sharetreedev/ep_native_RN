{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#9AAD82"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs microphone access to enable voice conversations with Pulse AI."
      },
      "bundleIdentifier": "com.vative.stemotionalpulse",
      "appleTeamId": "PL8F7LAM2G"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#9AAD82"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sharetree.emotionalpulse"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ]
  }
}
